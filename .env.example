# Copy this to .env and fill in values (never commit .env)

# ── AWS / S3 output (Source Cooperative) ─────────────────────────────────────
# Bare bucket name (no s3:// scheme, no trailing slash)
S3_BUCKET=us-west-2.opendata.source.coop
S3_PREFIX=walkthru-earth/indices
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-west-2

# ── Hetzner Cloud (for GitHub Actions runner) ────────────────────────────────
HCLOUD_TOKEN=your-hetzner-api-token
PERSONAL_ACCESS_TOKEN=access-token-gh

# ── Pipeline config overrides (all optional) ─────────────────────────────────
# Leave empty to auto-detect latest from STAC catalog
OVERTURE_RELEASE=
# Comma-separated themes (default: all 5)
OVERTURE_THEMES=transportation,places,buildings,addresses,base
